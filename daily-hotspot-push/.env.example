# 搜索API地址（使用已部署的国内搜索代理服务）
SEARCH_API=http://127.0.0.1:8300/res/v1/web/search

# 飞书群自定义机器人Webhook地址（必填，在飞书群设置->机器人->添加自定义机器人获取）
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/你的机器人webhook密钥

# 目标飞书群ID
FEISHU_CHAT_ID=oc_c54312d70f4b25f669391cbeb7842208

# 每日推送时间（默认早9点）
PUSH_TIME=09:00

# 推送失败重试次数
RETRY_TIMES=2
